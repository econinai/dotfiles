#!/usr/bin/env bash

{{ template "sudo.tmpl" . }}
{{ template "pkg_install.tmpl" . }}

# {{ include ".assets/packageList" | sha256sum }}

pkg_install "$(awk '{for(i=1;i<=NF;i++) printf "%s ", $i; } END {print ""}' {{ .chezmoi.sourceDir }}/.assets/packageList)"

### noctalia greeter

echo -e "Installing greeter..." 2>&1 | tee -a log.txt

sudo cp "{{ .chezmoi.sourceDir }}/.assets/greetdconfig.toml" "/etc/greetd/config.toml" >> log.txt 2>&1

sudo systemctl disable display-manager.service >> log.txt 2>&1

sudo systemctl enable greetd >> log.txt 2>&1

### hyprland plugins

echo -e "Installing hyprland plugins..." 2>&1 | tee -a log.txt

if [[ $(awk "/^hyprland$/" {{ .chezmoi.sourceDir }}/.assets/packageList) != "" ]]; then
  hyprpm update >> log.txt 2>&1
  hyprpm add https://github.com/hyprnux/hyprglass >> log.txt 2>&1
  hyprpm enable hyprglass >> log.txt 2>&1
  hyprpm add https://github.com/virtcode/hypr-dynamic-cursors >> log.txt 2>&1
  hyprpm enable dynamic-cursors >> log.txt 2>&1
fi;

### auto-cpufreq

if [[ $(awk "/^auto-cpufreq$/" {{ .chezmoi.sourceDir }}/.assets/packageList) != "" ]]; then
  sudo cp {{ .chezmoi.sourceDir }}/.assets/auto-cpufreq.conf /etc/auto-cpufreq.conf >> log.txt 2>&1
  sudo systemctl enable auto-cpufreq  >> log.txt 2>&1
fi;

### pacman-contrib

if [[ $(awk "/^pacman-contrib$/" {{ .chezmoi.sourceDir }}/.assets/packageList) != "" ]]; then
  sudo systemctl enable --now paccache.timer >> log.txt 2>&1
fi;

